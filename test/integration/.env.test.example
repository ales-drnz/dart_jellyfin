# Integration test configuration for dart_jellyfin.
#
# Copy this file to `.env.test` (which is gitignored) and adjust
# values for your local setup. Never commit `.env.test` itself.
#
# Jellyfin is self-contained — no external account or claim token
# is needed. The first-run bootstrap creates the admin user locally
# inside the Docker container, using the credentials below.

# Local admin credentials. Pick anything — they never leave the
# Docker container exposed only on 127.0.0.1.
JELLYFIN_TEST_USERNAME=test_admin
JELLYFIN_TEST_PASSWORD=test_password_change_me

# Docker image tag. Pin to a specific version so the suite stays
# deterministic across contributor machines.
JELLYFIN_IMAGE_TAG=10.11.9

# Exposed port on the host. Pick something unused so the test stack
# can run alongside a "real" Jellyfin on 8096.
JELLYFIN_HOST_PORT=18096
